<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:tools="http://schemas.android.com/tools"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:paddingLeft="@dimen/activity_horizontal_margin"
              android:paddingRight="@dimen/activity_horizontal_margin"
              android:paddingTop="@dimen/activity_vertical_margin"
              android:paddingBottom="@dimen/activity_vertical_margin"
              tools:context="com.example.quoson.mkryptos.PhotoActivity"
              android:background="#ffc7bfbd"
              android:orientation="vertical">


    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/scrollView3">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="10dp"
            >

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="10dip"
                >

                <ImageButton
                    android:layout_width="match_parent"
                    android:layout_height="50dip"
                    android:id="@+id/search_photo"
                    android:src="@drawable/search_photo"
                    android:layout_weight="1"
                    android:background="@drawable/border_off"
                    android:paddingBottom="5dip"
                    android:paddingTop="5dip"
                    android:layout_marginRight="5dip"
                    android:layout_marginLeft="5dip"/>

                <ImageButton
                    android:layout_width="match_parent"
                    android:layout_height="50dip"
                    android:id="@+id/click_cipher"
                    android:background="@drawable/border_off"
                    android:src="@drawable/icon_close_on"
                    android:layout_weight="1"
                    android:layout_marginRight="5dip"
                    android:layout_marginLeft="5dip"/>

                <ImageButton
                    android:layout_width="match_parent"
                    android:layout_height="50dip"
                    android:id="@+id/click_decoding"
                    android:background="@drawable/border_off"
                    android:src="@drawable/icon_open_on"
                    android:layout_weight="1"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"/>
            </LinearLayout>

            <ImageView
                android:layout_width="fill_parent"
                android:layout_height="200dip"
                android:id="@+id/original_photo"
                android:layout_marginBottom="10dip"
                android:hint="@string/menuConsole2"
                android:gravity="top|left"
                android:minHeight="50dip"
                android:maxHeight="150dip"
                android:visibility="gone"/>

            <Spinner
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:entries="@array/array_keys"
                android:id="@+id/select_algorithm"
                android:layout_marginBottom="10dip"
                android:hint="@string/menuConsole2"
                android:background="@drawable/border4"
                android:minHeight="45dip"
                android:padding="10dip"/>
            <EditText
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:id="@+id/editKey"
                android:background="@drawable/border2"
                android:hint="@string/menuConsole2"
                android:drawableLeft="@drawable/icon_key"
                android:drawablePadding="10dip"
                android:layout_marginBottom="10dip"
                android:padding="10dip"
                android:textIsSelectable="false"
                android:textSize="20dip"
                android:minHeight="45dip"/>

            <ImageView
                android:layout_width="fill_parent"
                android:layout_height="200dip"
                android:id="@+id/cipher_photo"
                android:hint="@string/menuConsole2"
                android:gravity="top|left"
                android:minHeight="50dip"
                android:layout_gravity="center"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>


</LinearLayout>