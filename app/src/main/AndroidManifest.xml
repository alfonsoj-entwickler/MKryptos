<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.quoson.mkryptos" >

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/icon_main"
        android:label="@string/app_name"
        android:theme="@style/AppTheme" >
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".AboutActivity"
            android:label="@string/title_activity_about" >
        </activity>
        <activity
            android:name=".YourMessageActivity"
            android:label="@string/title_activity_your_message" >
        </activity>
        <activity
            android:name=".YourFilesActivity"
            android:label="@string/title_activity_your_files" >
        </activity>
        <activity
            android:name=".VoiceActivity"
            android:label="@string/title_activity_voice" >
        </activity>
        <activity
            android:name=".VideoActivity"
            android:label="@string/title_activity_video" >
        </activity>
        <activity
            android:name=".PhotoActivity"
            android:label="@string/title_activity_photo" >
        </activity>
        <activity
            android:name=".NumbersActivity"
            android:label="@string/title_activity_numbers" >
        </activity>
        <activity
            android:name=".KeysActivity"
            android:label="@string/title_activity_keys" >
        </activity>
        <activity
            android:name=".YourKeysActivity"
            android:label="@string/title_activity_your_keys" >
        </activity>
        <activity
            android:name=".ShowInformationActivity"
            android:label="@string/title_activity_show_information" >
        </activity>
        <activity
            android:name=".YourSignatureActivity"
            android:label="@string/title_activity_your_signature" >
        </activity>
    </application>

</manifest>
